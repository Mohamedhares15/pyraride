generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GalleryItem {
  id         String            @id @default(uuid())
  url        String
  caption    String?
  status     GalleryItemStatus @default(pending)
  uploadedBy String?
  reviewedBy String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  reviewer   User?             @relation("GalleryReviewer", fields: [reviewedBy], references: [id])

  @@index([status])
}

model Location {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id                     String                      @id @default(uuid())
  email                  String                      @unique
  phoneNumber            String?                     @unique
  passwordHash           String
  profileImageUrl        String?
  fullName               String?
  role                   Role                        @default(rider)
  hasPremiumAI           Boolean                     @default(false)
  premiumAIExpiresAt     DateTime?
  createdAt              DateTime                    @default(now())
  stableId               String?
  rankPoints             Int                         @default(1000)
  rankId                 String?
  currentLeagueId        String?
  gender                 Gender?
  profilePhoto           String?
  isTrustedRider         Boolean                     @default(false)
  bio                    String?
  pushToken              String?
  managedAcademy         Academy?                    @relation("AcademyCaptain")
  priceChangeRequests    AcademyPriceChangeRequest[] @relation("CaptainPriceChanges")
  priceChangeReviews     AcademyPriceChangeRequest[] @relation("AdminPriceChangeReviewer")
  bookings               Booking[]
  friendRequestsReceived Friend[]                    @relation("FriendsReceived")
  friendRequestsSent     Friend[]                    @relation("FriendsSent")
  reviewedGalleryItems   GalleryItem[]               @relation("GalleryReviewer")
  horseChangeReviews     HorseChangeRequest[]        @relation("HorseChangeReviewer")
  leagueStandings        LeagueStanding[]
  messages               Message[]                   @relation("MessageSender")
  notifications          Notification[]
  driverBookings         PackageBooking[]            @relation("DriverBookings")
  packageBookings        PackageBooking[]
  passwordResetTokens    PasswordResetToken[]
  postLikes              PostLike[]
  reviews                Review[]
  rideResults            RideResult[]
  riderReviewsGiven      RiderReview[]               @relation("StableOwnerReviews")
  riderReviewsReceived   RiderReview[]               @relation("RiderReviews")
  sessionReviewsGiven    SessionReview[]             @relation("CaptainSessionReviews")
  skillOverrideRequests  SkillOverrideRequest[]      @relation("RiderSkillRequests")
  ownedStables           Stable[]                    @relation("StableOwner")
  trainingEnrollments    TrainingEnrollment[]        @relation("TraineeEnrollments")
  currentLeague          League?                     @relation("RiderLeague", fields: [currentLeagueId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rank                   RiderRank?                  @relation(fields: [rankId], references: [id])
  stable                 Stable?                     @relation("StableOwners", fields: [stableId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  following              UserFollow[]                @relation("Followers")
  followers              UserFollow[]                @relation("Following")
  userPosts              UserPost[]                  @relation("UserPosts")
  conversations          Conversation[]              @relation("ConversationParticipants")
}

model RiderRank {
  id        String  @id @default(uuid())
  name      String  @unique
  minPoints Int
  maxPoints Int
  icon      String?
  users     User[]
}

model HorseTier {
  id        String  @id @default(uuid())
  name      String  @unique
  minPoints Int
  maxPoints Int
  icon      String?
  horses    Horse[]
}

model Stable {
  id               String        @id @default(uuid())
  name             String
  description      String
  location         String
  address          String
  imageUrl         String?
  status           StableStatus  @default(pending_approval)
  isHidden         Boolean       @default(false)
  commissionRate   Decimal       @default(0.15) @db.Decimal(5, 4)
  minLeadTimeHours Int           @default(8)
  createdAt        DateTime      @default(now())
  ownerId          String
  blockedSlots     BlockedSlot[]
  bookings         Booking[]
  horses           Horse[]
  packages         Package[]
  reviews          Review[]
  rideResults      RideResult[]
  owner            User          @relation("StableOwner", fields: [ownerId], references: [id], onUpdate: Restrict)
  owners           User[]        @relation("StableOwners")
}

model Horse {
  id                    String                 @id @default(uuid())
  stableId              String
  name                  String
  imageUrls             String[]
  pricePerHour          Decimal?               @db.Decimal(10, 2)
  discountPercent       Int?                   @db.Integer
  age                   Int?
  skills                String[]               @default([])
  isActive              Boolean                @default(true)
  availabilityStatus    AvailabilityStatus?    @default(available)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime?              @updatedAt
  rankPoints            Int                    @default(1400)
  tierId                String?
  adminTier             String?
  firstTimeFriendly     Boolean?
  skillLevel            SkillLevel             @default(BEGINNER)
  color                 String?
  blockedSlots          BlockedSlot[]
  bookings              Booking[]
  stable                Stable                 @relation(fields: [stableId], references: [id], onDelete: Cascade)
  tier                  HorseTier?             @relation(fields: [tierId], references: [id])
  changeRequests        HorseChangeRequest[]
  media                 HorseMedia[]
  reviews               Review[]
  rideResults           RideResult[]
  skillOverrideRequests SkillOverrideRequest[]
}

model BlockedSlot {
  id        String   @id @default(uuid())
  stableId  String
  horseId   String?
  startTime DateTime
  endTime   DateTime
  reason    String?
  createdAt DateTime @default(now())
  horse     Horse?   @relation(fields: [horseId], references: [id], onDelete: Cascade)
  stable    Stable   @relation(fields: [stableId], references: [id], onDelete: Cascade)

  @@index([stableId])
  @@index([horseId])
}

model RideResult {
  id           String   @id @default(uuid())
  bookingId    String   @unique
  riderId      String
  horseId      String
  stableId     String
  rps          Int
  pointsChange Int
  timestamp    DateTime @default(now())
  booking      Booking  @relation(fields: [bookingId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  horse        Horse    @relation(fields: [horseId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rider        User     @relation(fields: [riderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  stable       Stable   @relation(fields: [stableId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([riderId])
  @@index([stableId])
}

model HorseChangeRequest {
  id                   String                   @id @default(uuid())
  horseId              String
  status               HorseChangeRequestStatus @default(pending)
  proposedName         String?
  proposedPricePerHour Decimal?                 @db.Decimal(10, 2)
  proposedImageUrls    String[]
  reviewedBy           String?
  reviewedAt           DateTime?
  rejectionReason      String?
  requestedAt          DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  proposedColor        String?
  horse                Horse                    @relation(fields: [horseId], references: [id], onDelete: Cascade)
  reviewer             User?                    @relation("HorseChangeReviewer", fields: [reviewedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([status])
  @@index([horseId])
}

model HorseMedia {
  id           String         @id @default(uuid())
  horseId      String
  type         HorseMediaType
  url          String
  thumbnailUrl String?
  sortOrder    Int?
  createdAt    DateTime       @default(now())
  horse        Horse          @relation(fields: [horseId], references: [id], onDelete: Cascade)
}

model Booking {
  id                 String        @id @default(uuid())
  riderId            String
  stableId           String
  horseId            String
  startTime          DateTime
  endTime            DateTime
  totalPrice         Decimal
  commission         Decimal
  status             BookingStatus @default(confirmed)
  stripePaymentId    String?       @unique
  refundStatus       String?
  refundAmount       Decimal?
  stripeRefundId     String?
  refundReason       String?
  cancellationReason String?
  rescheduledFrom    DateTime?
  rescheduledTo      DateTime?
  isRescheduled      Boolean       @default(false)
  cancelledBy        String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  promoCodeId        String?
  groupDiscount      Decimal?      @db.Decimal(10, 2)
  groupSize          Int           @default(1)
  reminderSent       Boolean       @default(false)
  horse              Horse         @relation(fields: [horseId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  promoCode          PromoCode?    @relation(fields: [promoCodeId], references: [id])
  rider              User          @relation(fields: [riderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  stable             Stable        @relation(fields: [stableId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  review             Review?
  rideResult         RideResult?
  riderReview        RiderReview?
}

model Review {
  id           String        @id @default(uuid())
  bookingId    String        @unique
  riderId      String
  stableId     String
  horseId      String
  stableRating Int
  horseRating  Int
  comment      String
  createdAt    DateTime      @default(now())
  photos       String[]
  booking      Booking       @relation(fields: [bookingId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  horse        Horse         @relation(fields: [horseId], references: [id])
  rider        User          @relation(fields: [riderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  stable       Stable        @relation(fields: [stableId], references: [id])
  reviewMedias ReviewMedia[]
}

model RiderReview {
  id               String   @id @default(uuid())
  bookingId        String   @unique
  riderId          String
  ownerId          String
  ridingSkillLevel Int
  behaviorRating   Int
  comment          String?
  createdAt        DateTime @default(now())
  booking          Booking  @relation(fields: [bookingId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  stableOwner      User     @relation("StableOwnerReviews", fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rider            User     @relation("RiderReviews", fields: [riderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model NewsletterSubscriber {
  id           String   @id @default(uuid())
  email        String   @unique
  subscribedAt DateTime @default(now())
  status       String   @default("active")
  source       String?
}

model LoyaltyPoints {
  id           String              @id @default(uuid())
  userId       String              @unique
  points       Int                 @default(0)
  tier         String              @default("bronze")
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  transactions PointsTransaction[]
}

model PointsTransaction {
  id              String        @id @default(uuid())
  loyaltyPointsId String
  amount          Int
  type            String
  description     String?
  createdAt       DateTime      @default(now())
  loyaltyPoints   LoyaltyPoints @relation(fields: [loyaltyPointsId], references: [id], onDelete: Cascade)

  @@index([loyaltyPointsId])
}

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Subscription {
  id             String   @id @default(uuid())
  userId         String
  planType       String
  ridesRemaining Int?
  ridesUsed      Int      @default(0)
  startDate      DateTime @default(now())
  endDate        DateTime
  isActive       Boolean  @default(true)
  price          Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([isActive])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model League {
  id              String           @id @default(uuid())
  name            LeagueName
  startDate       DateTime
  endDate         DateTime
  status          LeagueStatus     @default(active)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  nextLeagueId    String?
  nextLeague      League?          @relation("LeaguePromotion", fields: [nextLeagueId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  previousLeagues League[]         @relation("LeaguePromotion")
  standings       LeagueStanding[]
  riders          User[]           @relation("RiderLeague")

  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model LeagueStanding {
  id         String   @id @default(uuid())
  leagueId   String
  riderId    String
  rankPoints Int
  finalRank  Int?
  promoted   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  league     League   @relation(fields: [leagueId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rider      User     @relation(fields: [riderId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([leagueId, riderId])
  @@index([leagueId])
  @@index([riderId])
  @@index([finalRank])
}

model PromoCode {
  id             String    @id @default(uuid())
  code           String    @unique
  discountType   String    @default("percentage")
  discountAmount Decimal   @db.Decimal(10, 2)
  expiresAt      DateTime?
  maxUses        Int?
  currentUses    Int       @default(0)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  bookings       Booking[]
}

model Friend {
  id         String       @id @default(uuid())
  senderId   String
  receiverId String
  status     FriendStatus @default(pending)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  receiver   User         @relation("FriendsReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User         @relation("FriendsSent", fields: [senderId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
  @@index([status])
}

model Conversation {
  id           String    @id @default(uuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  messages     Message[]
  participants User[]    @relation("ConversationParticipants")

  @@index([updatedAt])
}

model Message {
  id             String       @id @default(uuid())
  content        String
  createdAt      DateTime     @default(now())
  read           Boolean      @default(false)
  senderId       String
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

model SkillOverrideRequest {
  id        String             @id @default(uuid())
  riderId   String
  horseId   String
  stableId  String
  reason    String?
  status    SkillRequestStatus @default(pending)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  horse     Horse              @relation(fields: [horseId], references: [id], onDelete: Cascade)
  rider     User               @relation("RiderSkillRequests", fields: [riderId], references: [id], onDelete: Cascade)

  @@index([riderId])
  @@index([horseId])
  @@index([stableId])
  @@index([status])
}

model UserFollow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("Followers", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model UserPost {
  id        String     @id @default(uuid())
  userId    String
  imageUrl  String
  caption   String?
  createdAt DateTime   @default(now())
  likes     PostLike[]
  user      User       @relation("UserPosts", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      UserPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model ReviewMedia {
  id        String   @id @default(uuid())
  reviewId  String
  url       String
  createdAt DateTime @default(now())
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
}

model Package {
  id                 String           @id @default(uuid())
  title              String
  description        String
  price              Float
  duration           Float
  maxPeople          Int
  included           String[]
  highlights         String[]
  imageUrl           String
  isActive           Boolean          @default(true)
  isFeatured         Boolean          @default(false)
  sortOrder          Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  availableDays      String[]
  hasDancingShow     Boolean          @default(false)
  hasFood            Boolean          @default(false)
  hasHorseRide       Boolean          @default(true)
  hasParty           Boolean          @default(false)
  hasTransportation  Boolean          @default(false)
  minPeople          Int              @default(1)
  originalPrice      Float?
  packageType        String           @default("PRIVATE")
  startTime          String?
  transportationType String?
  stableId           String?
  minLeadTimeHours   Int              @default(8)
  stable             Stable?          @relation(fields: [stableId], references: [id])
  bookings           PackageBooking[]

  @@index([isActive])
  @@index([isFeatured])
  @@index([sortOrder])
  @@index([packageType])
  @@index([stableId])
}

model PackageBooking {
  id                 String          @id @default(uuid())
  riderId            String
  packageId          String
  date               DateTime        @db.Date
  startTime          String
  ticketsCount       Int             @default(1)
  totalPrice         Decimal
  status             BookingStatus   @default(confirmed)
  stripePaymentId    String?         @unique
  commission         Decimal?
  refundStatus       String?
  refundAmount       Decimal?
  stripeRefundId     String?
  refundReason       String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  transportationZone String?
  pickupLocationUrl  String?
  driverId           String?
  driverStatus       TransportStatus @default(pending)
  driver             User?           @relation("DriverBookings", fields: [driverId], references: [id])
  package            Package         @relation(fields: [packageId], references: [id])
  rider              User            @relation(fields: [riderId], references: [id])

  @@index([riderId])
  @@index([packageId])
  @@index([driverId])
  @@index([date])
}

model TransportZone {
  id        String   @id @default(uuid())
  name      String
  price     Decimal
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Academy {
  id            String                      @id @default(uuid())
  name          String
  description   String
  location      String
  address       String
  imageUrl      String?
  isActive      Boolean                     @default(true)
  isHidden      Boolean                     @default(false)
  captainId     String                      @unique
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt
  googleMapsUrl String?
  captain       User                        @relation("AcademyCaptain", fields: [captainId], references: [id], onUpdate: Restrict)
  priceChanges  AcademyPriceChangeRequest[]
  enrollments   TrainingEnrollment[]
  programs      TrainingProgram[]

  @@index([isActive])
  @@index([location])
}

model TrainingProgram {
  id              String               @id @default(uuid())
  academyId       String
  name            String
  description     String
  skillLevel      SkillLevel           @default(BEGINNER)
  price           Decimal              @db.Decimal(10, 2)
  totalSessions   Int
  sessionDuration Float                @default(1)
  validityDays    Int                  @default(60)
  availableDays   String[]
  startTime       String?
  isActive        Boolean              @default(true)
  sortOrder       Int                  @default(0)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  enrollments     TrainingEnrollment[]
  academy         Academy              @relation(fields: [academyId], references: [id], onDelete: Cascade)

  @@index([academyId])
  @@index([isActive])
  @@index([skillLevel])
}

model TrainingEnrollment {
  id                String                @id @default(uuid())
  riderId           String
  academyId         String
  programId         String
  status            TrainingBookingStatus @default(active)
  totalSessions     Int
  completedSessions Int                   @default(0)
  startDate         DateTime              @db.Date
  expiryDate        DateTime              @db.Date
  totalPrice        Decimal               @db.Decimal(10, 2)
  stripePaymentId   String?               @unique
  commission        Decimal?              @db.Decimal(10, 2)
  renewedFromId     String?
  isRenewed         Boolean               @default(false)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  amountPaid        Decimal               @default(0) @db.Decimal(10, 2)
  balanceDue        Decimal               @default(0) @db.Decimal(10, 2)
  paymentMethod     PaymentMethod         @default(CASH)
  paymentStructure  PaymentStructure      @default(FULL)
  academy           Academy               @relation(fields: [academyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  program           TrainingProgram       @relation(fields: [programId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rider             User                  @relation("TraineeEnrollments", fields: [riderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sessions          TrainingSession[]

  @@index([riderId])
  @@index([academyId])
  @@index([programId])
  @@index([status])
}

model TrainingSession {
  id                String                @id @default(uuid())
  enrollmentId      String
  sessionNumber     Int
  date              DateTime              @db.Date
  startTime         String
  endTime           String
  status            TrainingSessionStatus @default(scheduled)
  originalDate      DateTime?             @db.Date
  originalStartTime String?
  rescheduledAt     DateTime?
  rescheduleReason  String?
  completedAt       DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  review            SessionReview?
  enrollment        TrainingEnrollment    @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([enrollmentId])
  @@index([date])
  @@index([status])
}

model SessionReview {
  id                String          @id @default(uuid())
  sessionId         String          @unique
  captainId         String
  performanceRating Int
  techniqueRating   Int
  attitudeRating    Int
  comment           String?
  improvements      String?
  createdAt         DateTime        @default(now())
  captain           User            @relation("CaptainSessionReviews", fields: [captainId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  session           TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model AcademyPriceChangeRequest {
  id              String                   @id @default(uuid())
  academyId       String
  captainId       String
  programId       String
  currentPrice    Decimal                  @db.Decimal(10, 2)
  proposedPrice   Decimal                  @db.Decimal(10, 2)
  reason          String?
  status          AcademyPriceChangeStatus @default(pending)
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  academy         Academy                  @relation(fields: [academyId], references: [id], onDelete: Cascade)
  captain         User                     @relation("CaptainPriceChanges", fields: [captainId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reviewer        User?                    @relation("AdminPriceChangeReviewer", fields: [reviewedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([academyId])
  @@index([status])
}

enum Role {
  rider
  stable_owner
  admin
  cx_media
  captain
  driver
}

enum GalleryItemStatus {
  pending
  approved
  rejected
}

enum Gender {
  male
  female
}

enum LeagueName {
  wood
  bronze
  silver
  gold
  platinum
  elite
  champion
}

enum LeagueStatus {
  active
  ended
}

enum BookingStatus {
  pending
  confirmed
  completed
  cancelled
  rescheduled
}

enum TransportStatus {
  pending
  assigned
  in_transit
  arrived
  completed
}

enum StableStatus {
  pending_approval
  approved
  rejected
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum HorseMediaType {
  image
  video
}

enum AvailabilityStatus {
  available
  injured
  unavailable
}

enum HorseChangeRequestStatus {
  pending
  approved
